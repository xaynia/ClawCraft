# Required environment variables for ClawCraft
# Copy this to .env and fill in your actual values. NEVER commit .env.

OPENCLAW_CONFIG_DIR=/path/to/.openclaw
OPENCLAW_WORKSPACE_DIR=/path/to/.openclaw/workspace
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=loopback
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here
OPENCLAW_IMAGE=openclaw:local

# API Keys
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Notion Integration
NOTION_TOKEN=ntn_your-notion-token-here
NOTION_RENDERS_DB=your-renders-db-id
NOTION_SCENES_DB=your-scenes-db-id
NOTION_TASKS_DB=your-tasks-db-id
NOTION_MILESTONES_DB=your-milestones-db-id
